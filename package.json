{
  "name": "virtualizorjs",
  "version": "2.0.0",
  "description": "TypeScript SDK for the Virtualizor server management API. Create, start, stop, restart, rebuild, and manage VPS instances with a type-safe, developer-friendly client.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "release": "npm run build && bumpp && npm publish --access public",
    "prepublishOnly": "npm run build && npm run typecheck",
    "check-exports": "attw --pack .",
    "prepare": "husky"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "virtualizor",
    "vps",
    "sdk",
    "api",
    "typescript",
    "nodejs"
  ],
  "author": "kkMihai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kkMihai/virtualizorjs.git"
  },
  "bugs": {
    "url": "https://github.com/kkMihai/virtualizorjs/issues"
  },
  "homepage": "https://github.com/kkMihai/virtualizorjs#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "bumpp": "^9.0.0",
    "husky": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
